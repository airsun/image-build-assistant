# 环境配置模板
# 每个局域网环境一份，存放在 remote-envs/{env-name}.env
# 项目通过 projects.yaml 的 env 字段声明归属环境

# === Build Host (required) ===
REMOTE_HOST=build.example.internal
REMOTE_PORT=22
REMOTE_USER=builder
SSH_KEY_PATH=~/.ssh/id_rsa
REMOTE_BASE_DIR=/opt/image-build-assistant
PLATFORM=linux/amd64

# === Harbor (optional) ===
# 不填 HARBOR_HOST 时镜像 tag 为纯 IMAGE_NAME:VERSION，不 push
HARBOR_HOST=harbor.example.com
HARBOR_PROJECT=library
PUSH=true

# === Deploy Host (optional, k8s deploy intent only) ===
DEPLOY_HOST=deploy.example.internal
DEPLOY_PORT=22
DEPLOY_USER=deployer
DEPLOY_SSH_KEY_PATH=~/.ssh/id_deploy
DEPLOY_BASE_DIR=/opt/k8s-deploys
